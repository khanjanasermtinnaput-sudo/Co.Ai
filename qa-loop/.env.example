# Co.AI QA Loop — environment configuration
# Copy to .env and fill in your values

# ── Targets ─────────────────────────────────────────────────────────────────
QA_BASE_URL=https://aof-web.vercel.app
QA_BACKEND_URL=https://aof-code.onrender.com

# ── Auth (needed for Phases 2, 4) ───────────────────────────────────────────
QA_TEST_EMAIL=your-test-account@example.com
QA_TEST_PASSWORD=your-test-password
QA_SUPABASE_URL=https://xuupsckszsujfnrzodtw.supabase.co
QA_SUPABASE_ANON_KEY=

# ── Browser ──────────────────────────────────────────────────────────────────
# Set to "false" to show the browser window during tests
QA_HEADLESS=true
QA_SCREENSHOTS=true

# ── Loop ─────────────────────────────────────────────────────────────────────
# Comma-separated list of phases to run (1-9). Omit to run all.
QA_PHASES=1,2,3,4,5,6,7,8,9
# Milliseconds to wait between loop iterations (default 60 s)
QA_LOOP_INTERVAL_MS=60000

# ── Stress test ──────────────────────────────────────────────────────────────
# Cap concurrent users. Max 1000 — caution: high values DDoS free Render tier.
QA_MAX_STRESS_USERS=100

# ── Misc ─────────────────────────────────────────────────────────────────────
QA_TIMEOUT_MS=30000
QA_REPORT_DIR=./reports

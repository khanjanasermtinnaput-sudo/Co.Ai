# ── AI providers (server-side, powers /api/chat) ──────────────────────────────
# Coagentix picks a provider chain based on the task (chat/coding/research/
# reasoning — see src/lib/server/model-registry.ts), trying each configured
# provider in turn: Gemini → Claude → DeepSeek → Qwen → Llama → OpenRouter.
# Set at least one so Chat + Coagentix Code can answer. These are server-only
# secrets — never prefix with NEXT_PUBLIC. A signed-in user's own key
# (Settings → API Keys) always takes priority over these env vars for that
# provider.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
LLAMA_API_KEY=
# Optional model overrides (sensible defaults are used when blank):
ANTHROPIC_MODEL=
OPENROUTER_MODEL=
GEMINI_MODEL=
DEEPSEEK_MODEL=
QWEN_MODEL=
LLAMA_MODEL=

# ── Universal Search (server-side) ────────────────────────────────────────────
# Powers the Web Search toggle (AUTO / OFF / FORCE). GitHub / Wikipedia /
# Reddit are keyless. Add the keys below for high-quality general results.
TAVILY_API_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
GITHUB_TOKEN=

# ── Subscription enforcement (OFF by default until billing is live) ───────────
# When unset/0, any signed-in user gets full feature access (guests still
# capped at 3 messages). Set to 1 once billing is wired.
NEXT_PUBLIC_COAGENTIX_ENFORCE_PLANS=

# ── Offline demo mode (opt-in, OFF by default) ────────────────────────────────
# Set to 1 to use the simulated offline mock engine instead of real providers.
# SIMULATED responses only — never use in production.
NEXT_PUBLIC_COAGENTIX_DEMO=

# ── Coagentix frontend configuration ─────────────────────────────────────────
# Base URL of the tmap-v2 backend (Express, serves /v1/*). OPTIONAL — when
# unset those actions fall back to a serverless single-pass generation through
# /api/chat.

# Public base the browser calls directly (use for cross-origin dev):
# Example: http://localhost:8787
NEXT_PUBLIC_COAGENTIX_API_BASE=

# Server-side proxy target. When set, Next rewrites /v1/* → $COAGENTIX_API_PROXY/v1/*
# so the browser stays same-origin (recommended for production).
# Example: http://localhost:8787
COAGENTIX_API_PROXY=

# ── Supabase (auth + projects persistence) ────────────────────────────────────
# Leave BOTH blank to run offline demo mode. Set both to enable Google sign-in
# + per-user project storage. Find in Supabase Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-side secrets for encrypted API-key storage (/api/keys) ─────────────
# Required to persist AI provider keys against the signed-in account.
# Both are server-only — NEVER prefix with NEXT_PUBLIC.
# SUPABASE_SERVICE_ROLE_KEY: Supabase Dashboard → Settings → API (keep secret!)
# COAGENTIX_MASTER_KEY: any long random string used to encrypt keys at rest.
#   Generate with: openssl rand -hex 32
SUPABASE_SERVICE_ROLE_KEY=
COAGENTIX_MASTER_KEY=

# ── Redis (cache layer, session store, pub/sub, BullMQ queues) ────────────────
# Provide REDIS_URL for a hosted Redis (e.g. Upstash, Railway, Render).
# Use REDIS_TLS_URL for TLS-enabled instances (rediss:// protocol).
# Omit to disable Redis features (cache falls back to in-process; queues disabled).
# Example: redis://default:password@host:6379
REDIS_URL=
# Example (TLS): rediss://default:password@host:6380
REDIS_TLS_URL=
# Alternative (if not using a URL):
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Embeddings (semantic memory — pgvector) ───────────────────────────────────
# OpenAI key for text-embedding-3-small (1536 dims). Takes priority.
# Falls back to OPENROUTER_API_KEY (same model via proxy), then GEMINI_API_KEY.
# When all are absent, mock embeddings are used (not semantically useful).
OPENAI_API_KEY=

# ── BullMQ worker concurrency (optional, tmap-v2 only) ────────────────────────
QUEUE_EMBED_CONCURRENCY=4
QUEUE_CONSOL_CONCURRENCY=2
QUEUE_PRUNE_CONCURRENCY=1
QUEUE_TMAP_CONCURRENCY=3
QUEUE_NOTIFY_CONCURRENCY=5

# ── Monitoring & Observability (Phase 2, optional) ─────────────────────────────
# Sentry browser + server error tracking. Both public (client-side) and
# server-only (source map upload) DSNs come from the same Sentry project.
# NEXT_PUBLIC_SENTRY_DSN: shown in the browser bundle — use the DSN from
#   your Sentry project's Client Keys page (safe to expose).
NEXT_PUBLIC_SENTRY_DSN=
# Optional: Sentry release tag for source-map association (set in CI).
NEXT_PUBLIC_SENTRY_RELEASE=
# Sentry org + project slugs for CI source-map upload via withSentryConfig.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_TRACES_SAMPLE_RATE=0.1
# OpenTelemetry OTLP endpoint — @vercel/otel reads this automatically.
# Example: https://tempo.example.com
OTEL_EXPORTER_OTLP_ENDPOINT=
# Debug verbose logging
CGNTX_DEBUG=0

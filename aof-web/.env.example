# ── AI providers (server-side, powers /api/chat) ──────────────────────────────
# Nexora picks a provider chain based on the task (chat/coding/research/reasoning —
# see src/lib/server/model-registry.ts), trying each configured provider in turn
# and failing over on error: Gemini → Claude → DeepSeek → Qwen → Llama → OpenRouter.
# Set at least one so Chat + Nexora Code can answer. These are server-only secrets —
# never prefix with NEXT_PUBLIC. A signed-in user's own key (Settings → API Keys)
# always takes priority over these env vars for that provider.
#
# If NONE are set, Nexora does NOT fake a reply — it surfaces NEXORA_ERROR_001
# (API Key Missing) and tells you exactly which variable to add. Provider health
# is visible at Settings → Diagnostics (and GET /api/health).
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
LLAMA_API_KEY=
# Optional model overrides (sensible defaults are used when blank):
ANTHROPIC_MODEL=
OPENROUTER_MODEL=
GEMINI_MODEL=
DEEPSEEK_MODEL=
QWEN_MODEL=
LLAMA_MODEL=

# ── Universal Search (server-side, grounds replies in live web results) ───────
# Powers the Web Search toggle (AUTO / OFF / FORCE). Providers are tried in
# priority order and fail over automatically; GitHub / Wikipedia / Reddit are
# keyless and always available, so search works with zero config — set a key
# below to add high-quality general web results. All server-only (no NEXT_PUBLIC).
#   Tavily       → https://tavily.com (purpose-built LLM web search)
#   Google CSE   → https://programmablesearchengine.google.com (needs key + cx id)
#   GitHub token → optional, raises the keyless GitHub search rate limit
TAVILY_API_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
GITHUB_TOKEN=

# ── Subscription enforcement (OFF by default until billing is live) ───────────
# When unset/0, plan gating is lenient: any signed-in user gets full feature
# access (guests still capped at 3 messages), so the app works before checkout
# exists. Set to 1 once a billing provider is wired to enforce FREE/LITE/PRO/
# ADVANCED limits per src/lib/plans.ts.
NEXT_PUBLIC_NEXORA_ENFORCE_PLANS=

# ── Offline demo mode (opt-in, OFF by default) ────────────────────────────────
# Set to 1 to use the simulated offline mock engine instead of real providers.
# This produces SIMULATED responses — only for local UI demos. Leave blank in any
# environment where provider transparency matters.
NEXT_PUBLIC_NEXORA_DEMO=

# ── Nexora frontend configuration ────────────────────────────────────────────────
# Base URL of the tmap-v2 backend (Express, serves /v1/*). Powers the FULL Nexora Code
# build pipeline (multi-agent TMAP: Generate / Plan / Analyze / Debug). OPTIONAL:
# when unset, those actions fall back to a serverless single-pass generation through
# /api/chat (same provider chain) — set it for the richer multi-agent pipeline.

# Public base the browser calls directly (use for cross-origin dev).
# Example: http://localhost:8787
NEXT_PUBLIC_NEXORA_API_BASE=

# Server-side proxy target. When set, Next rewrites /v1/* → $NEXORA_API_PROXY/v1/*
# so the browser stays same-origin (recommended for production).
# Example: http://localhost:8787
NEXORA_API_PROXY=

# ── Supabase (auth + projects persistence) ────────────────────────────────────
# Leave BOTH blank to run the app in offline demo mode (seed projects, stand-in
# user, no login). Set both to enable Google sign-in + per-user project storage.
# Find these in Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-side secrets for encrypted API-key storage (/api/keys) ─────────────
# Required to persist AI provider keys against the signed-in account. Both are
# server-only — never prefix with NEXT_PUBLIC. SUPABASE_SERVICE_ROLE_KEY is in
# Supabase Dashboard → Project Settings → API (keep it secret!). NEXORA_MASTER_KEY is
# any long random string used to encrypt keys at rest (e.g. `openssl rand -hex 32`).
SUPABASE_SERVICE_ROLE_KEY=
NEXORA_MASTER_KEY=

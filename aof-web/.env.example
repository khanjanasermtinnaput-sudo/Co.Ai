# ── Aof frontend configuration ────────────────────────────────────────────────
# Base URL of the tmap-v2 backend (Express, serves /v1/*). Leave BOTH unset to run
# the UI fully standalone in mock mode (streamed demo responses, no backend needed).

# Public base the browser calls directly (use for cross-origin dev).
# Example: http://localhost:8787
NEXT_PUBLIC_AOF_API_BASE=

# Server-side proxy target. When set, Next rewrites /v1/* → $AOF_API_PROXY/v1/*
# so the browser stays same-origin (recommended for production).
# Example: http://localhost:8787
AOF_API_PROXY=

# ── Supabase (auth + projects persistence) ────────────────────────────────────
# Leave BOTH blank to run the app in offline demo mode (seed projects, stand-in
# user, no login). Set both to enable Google sign-in + per-user project storage.
# Find these in Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-side secrets for encrypted API-key storage (/api/keys) ─────────────
# Required to persist AI provider keys against the signed-in account. Both are
# server-only — never prefix with NEXT_PUBLIC. SUPABASE_SERVICE_ROLE_KEY is in
# Supabase Dashboard → Project Settings → API (keep it secret!). AOF_MASTER_KEY is
# any long random string used to encrypt keys at rest (e.g. `openssl rand -hex 32`).
SUPABASE_SERVICE_ROLE_KEY=
AOF_MASTER_KEY=

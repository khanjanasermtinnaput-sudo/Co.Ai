# ── AI providers (server-side, powers /api/chat) ──────────────────────────────
# Co.AI picks a provider chain based on the task (chat/coding/research/
# reasoning — see src/lib/server/model-registry.ts), trying each configured
# provider in turn: Gemini → Claude → DeepSeek → Qwen → Llama → OpenRouter.
# Set at least one so Chat + CoCode can answer. These are server-only
# secrets — never prefix with NEXT_PUBLIC. A signed-in user's own key
# (Settings → API Keys) always takes priority over these env vars for that
# provider.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
LLAMA_API_KEY=
# Optional model overrides (sensible defaults are used when blank):
ANTHROPIC_MODEL=
OPENROUTER_MODEL=
GEMINI_MODEL=
DEEPSEEK_MODEL=
QWEN_MODEL=
LLAMA_MODEL=

# ── Universal Search (server-side) ────────────────────────────────────────────
# Powers the Web Search toggle (AUTO / OFF / FORCE). GitHub / Wikipedia /
# Reddit are keyless. Add the keys below for high-quality general results.
TAVILY_API_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
GITHUB_TOKEN=

# ── Subscription enforcement (OFF by default until billing is live) ───────────
# When unset/0, any signed-in user gets full feature access (guests still
# capped at 3 messages). Set to 1 once billing is wired.
NEXT_PUBLIC_COAGENTIX_ENFORCE_PLANS=

# ── Offline demo mode (opt-in, OFF by default) ────────────────────────────────
# Set to 1 to use the simulated offline mock engine instead of real providers.
# SIMULATED responses only — never use in production.
NEXT_PUBLIC_COAGENTIX_DEMO=

# ── Co.AI frontend configuration ─────────────────────────────────────────────
# The public URL of this deployment (e.g. https://co-ai.railway.app).
# Used as HTTP-Referer on OpenRouter requests. Required on Railway.
NEXT_PUBLIC_SITE_URL=

# First-token timeout in ms for all streaming providers (default 6000).
# Increase if your provider consistently takes >6 s before streaming starts.
FIRST_TOKEN_TIMEOUT_MS=

# ── tmap-v2 multi-agent backend (Express, serves /v1/*) ───────────────────────
# This is the switch that turns Co.AI from a single-pass /api/chat wrapper
# into the full multi-agent platform (TMAP build, Titan, orchestrate, RAA, etc.).
# When NEITHER var below is set, those features fall back to a single-pass
# generation through /api/chat. Set ONE of the two:
#
#  • COAGENTIX_API_PROXY (recommended for production): server-side proxy target.
#    Next rewrites /v1/* → $COAGENTIX_API_PROXY/v1/* AND automatically marks the
#    client same-origin (see next.config.mjs), so this one var is enough — no
#    CORS, no second flag. Example: https://coagentix.onrender.com
COAGENTIX_API_PROXY=
#
#  • NEXT_PUBLIC_COAGENTIX_API_BASE: the browser calls the backend directly
#    (cross-origin). Use for local dev against a separate backend port. The
#    backend must allow this origin via COAGENTIX_ALLOWED_ORIGINS.
#    Example: http://localhost:8787
NEXT_PUBLIC_COAGENTIX_API_BASE=

# ── v2 engine canary (score-based RAA + DAG) ──────────────────────────────────
# Opt-in: route through the v2 engine (POST /v2/run) instead of the v1 paths —
# both BUILDS (else /v1/run) and universal CHAT (else /v1/orchestrate). Default
# off. Requires BOTH sides enabled: this flag here AND COAGENTIX_V2=1 on the
# backend (which mounts /v2/run). When either is unset, the unchanged v1 paths
# are used — safe, reversible canary.
NEXT_PUBLIC_COAGENTIX_V2=

# ── Supabase (auth + projects persistence) ────────────────────────────────────
# Leave BOTH blank to run offline demo mode. Set both to enable Google sign-in
# + per-user project storage. Find in Supabase Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-side secrets for encrypted API-key storage (/api/keys) ─────────────
# Required to persist AI provider keys against the signed-in account.
# Both are server-only — NEVER prefix with NEXT_PUBLIC.
# SUPABASE_SERVICE_ROLE_KEY: Supabase Dashboard → Settings → API (keep secret!)
# COAGENTIX_MASTER_KEY: any long random string used to encrypt keys at rest.
#   Generate with: openssl rand -hex 32
SUPABASE_SERVICE_ROLE_KEY=
COAGENTIX_MASTER_KEY=

{
  "name": "coagentix-cli",
  "version": "1.0.0",
  "description": "CoCode CLI — AI coding agent for your terminal (Advanced subscribers)",
  "keywords": [
    "ai",
    "cli",
    "coding",
    "coai"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "coai": "./bin/coai.js"
  },
  "main": "./dist/cli.js",

  },
  "clientApiBase": "aof-web/src/lib/api.ts — getApiBase()/isLive()/isDemoMode(); streams to /api/chat and (when configured) tmap-v2 /v1/* SSE",
  "proxy": "COAGENTIX_API_PROXY / NEXT_PUBLIC_COAGENTIX_API_BASE rewrites to tmap-v2 backend"

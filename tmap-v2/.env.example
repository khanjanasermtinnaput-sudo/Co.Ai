# ============================================================
#  Coagentix (tmap-v2) — API Keys
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ key ของคุณ
#  (คัดลอก:  คำสั่ง  ->  copy .env.example .env   บน PowerShell)
# ============================================================

# ---- ทางเลือกที่ง่ายที่สุด: ใช้ key เดียวครบทั้ง 4 โมเดล ----
# สมัครที่ https://openrouter.ai/keys  แล้ววาง key ที่นี่
OPENROUTER_API_KEY=

# ---- หรือ ใส่ key แยกราย provider (จะถูกใช้ก่อน OpenRouter) ----
# Planner agent  (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Coder agent    (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=
# Reviewer agent (https://dashscope.console.aliyun.com/  -> API-KEY)
QWEN_API_KEY=
DASHSCOPE_API_KEY=
# Validator agent (https://console.groq.com/keys)
LLAMA_API_KEY=
GROQ_API_KEY=

# ---- (ไม่บังคับ) override ชื่อโมเดลของแต่ละ provider ----
# GEMINI_MODEL=gemini-2.5-flash
# DEEPSEEK_MODEL=deepseek-chat
# QWEN_MODEL=qwen-plus
# LLAMA_MODEL=llama-3.3-70b-versatile

# ---- (ไม่บังคับ) Image Understanding pipeline (OCR + vision) ----
# โมเดลที่ใช้อ่านรูป (ต้องเป็น multimodal) — เลือกจาก Gemini / Qwen-VL / OpenRouter
# GEMINI_VISION_MODEL=gemini-2.5-flash
# QWEN_VISION_MODEL=qwen-vl-plus
# VISION_OPENROUTER_MODEL=google/gemini-2.5-flash
# ขนาดรูปสูงสุด (bytes) และอายุ memory (วัน)
# IMAGE_MAX_BYTES=10485760
# IMAGE_MEMORY_TTL_DAYS=30
# IMAGE_JSON_LIMIT=14mb

# ---- (ไม่บังคับ) โหมดเริ่มต้น: lite | normal | pro ----
COAGENTIX_MODE=normal

# ============================================================
#  SUPABASE (เชื่อม DB ถาวร — ถ้าไม่ตั้งจะใช้ไฟล์ /tmp แทน)
#  หา URL + Service Role Key ได้ที่:
#  Supabase Dashboard → Project → Settings → API
# ============================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
#  SERVER (โหมด web service — key ผูกกับ account ผู้ใช้)
#  จำเป็นต้องตั้ง 2 ค่านี้เมื่อรัน `npm run server`
#  สร้างค่าแบบสุ่ม:  openssl rand -hex 32
# ============================================================
# ใช้เซ็น JWT (session token ของผู้ใช้) — token อายุ 7 วัน
JWT_SECRET=
# ใช้เข้ารหัส API key ของผู้ใช้ก่อนเก็บลง DB (AES-256-GCM + scrypt KDF)
COAGENTIX_MASTER_KEY=
# พอร์ตเซิร์ฟเวอร์ (ค่าเริ่มต้น 8787)
PORT=8787
# CORS: รายชื่อ origin ที่อนุญาต (คั่นด้วยจุลภาค)
# ตัวอย่าง: COAGENTIX_ALLOWED_ORIGINS=https://coagentix.vercel.app
COAGENTIX_ALLOWED_ORIGINS=

# ============================================================
#  AOF Code — API Keys
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ key ของคุณ
#  (คัดลอก:  คำสั่ง  ->  copy .env.example .env   บน PowerShell)
# ============================================================

# ---- ทางเลือกที่ง่ายที่สุด: ใช้ key เดียวครบทั้ง 4 โมเดล ----
# สมัครที่ https://openrouter.ai/keys  แล้ววาง key ที่นี่
# ถ้าตั้งค่านี้ ระบบจะใช้ OpenRouter route ไปทุก agent อัตโนมัติ
OPENROUTER_API_KEY=

# ---- หรือ ใส่ key แยกราย provider (จะถูกใช้ก่อน OpenRouter) ----
# Planner agent  (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Coder agent    (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=
# Reviewer agent (https://dashscope.console.aliyun.com/  -> API-KEY)
DASHSCOPE_API_KEY=
# Validator agent (https://console.groq.com/keys  — รัน Llama ฟรี/เร็ว)
GROQ_API_KEY=

# ---- (ไม่บังคับ) override ชื่อโมเดลของแต่ละ provider ----
# GEMINI_MODEL=gemini-2.0-flash
# DEEPSEEK_MODEL=deepseek-chat
# QWEN_MODEL=qwen-plus
# LLAMA_MODEL=llama-3.3-70b-versatile

# ---- (ไม่บังคับ) โหมดเริ่มต้น: lite | normal | pro ----
AOF_MODE=normal

# ============================================================
#  SUPABASE (เชื่อม DB ถาวร — ถ้าไม่ตั้งจะใช้ไฟล์ /tmp แทน)
#  หา URL + Service Role Key ได้ที่:
#  Supabase Dashboard → Project → Settings → API
# ============================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
#  SERVER (โหมด web service — key ผูกกับ account ผู้ใช้)
#  จำเป็นต้องตั้ง 2 ค่านี้เมื่อรัน `npm run server`
#  สร้างค่าแบบสุ่ม:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
# ใช้เซ็น JWT (session token ของผู้ใช้) — token อายุ 7 วัน, refresh ผ่าน POST /v1/auth/refresh
JWT_SECRET=
# ใช้เข้ารหัส API key ของผู้ใช้ก่อนเก็บลง DB (AES-256-GCM + scrypt KDF) — แนะนำ 32+ ไบต์สุ่ม
AOF_MASTER_KEY=
# พอร์ตเซิร์ฟเวอร์ (ค่าเริ่มต้น 8787)
PORT=8787
# CORS: รายชื่อ origin ที่อนุญาต (คั่นด้วยจุลภาค) — ถ้าไม่ตั้งค่า production จะปฏิเสธทุก origin
# ตัวอย่าง: AOF_ALLOWED_ORIGINS=https://aof-web.vercel.app,https://aof.example.com
AOF_ALLOWED_ORIGINS=

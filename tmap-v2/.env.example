# ============================================================
#  Co.AI (tmap-v2) — API Keys
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ key ของคุณ
#  (คัดลอก:  คำสั่ง  ->  copy .env.example .env   บน PowerShell)
# ============================================================

# ---- ทางเลือกที่ง่ายที่สุด: ใช้ key เดียวครบทั้ง 4 โมเดล ----
# สมัครที่ https://openrouter.ai/keys  แล้ววาง key ที่นี่
OPENROUTER_API_KEY=sk-or-...your-key-here...

# ---- หรือ ใส่ key แยกราย provider (จะถูกใช้ก่อน OpenRouter) ----
# Planner agent  (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Coder agent    (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=
# Reviewer agent (https://dashscope.console.aliyun.com/  -> API-KEY)
QWEN_API_KEY=
DASHSCOPE_API_KEY=
# Validator agent (https://console.groq.com/keys)
LLAMA_API_KEY=
GROQ_API_KEY=
# Z.AI / GLM — ไม่ผูกกับ role ไหนโดยตรง ใช้เป็น fallback key หรือ override
# ROLE_PROVIDER เอง (https://z.ai/manage-apikey/apikey-list)
ZAI_API_KEY=

# ---- (ไม่บังคับ) override ชื่อโมเดลของแต่ละ provider ----
# GEMINI_MODEL=gemini-2.5-flash
# DEEPSEEK_MODEL=deepseek-chat
# QWEN_MODEL=qwen-plus
# LLAMA_MODEL=llama-3.3-70b-versatile
# ZAI_MODEL=glm-5.2

# ---- (ไม่บังคับ) Image Understanding pipeline (OCR + vision) ----
# โมเดลที่ใช้อ่านรูป (ต้องเป็น multimodal) — เลือกจาก Gemini / Qwen-VL / OpenRouter
# GEMINI_VISION_MODEL=gemini-2.5-flash
# QWEN_VISION_MODEL=qwen-vl-plus
# VISION_OPENROUTER_MODEL=google/gemini-2.5-flash
# ขนาดรูปสูงสุด (bytes) และอายุ memory (วัน)
# IMAGE_MAX_BYTES=10485760
# IMAGE_MEMORY_TTL_DAYS=30
# IMAGE_JSON_LIMIT=14mb

# ---- (ไม่บังคับ) โหมดเริ่มต้น: lite | normal | pro ----
COAGENTIX_MODE=normal

# ============================================================
#  SUPABASE (เชื่อม DB ถาวร — ถ้าไม่ตั้งจะใช้ไฟล์ /tmp แทน)
#  หา URL + Service Role Key ได้ที่:
#  Supabase Dashboard → Project → Settings → API
# ============================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
#  REDIS (Round 2 — บังคับใช้ข้าม instance: rate limit / quota / login lockout)
#  ถ้าไม่ตั้ง: ใช้ in-memory mock (ต่อ instance) เหมาะกับ dev เท่านั้น
#  Production บน serverless ต้องตั้ง REDIS_URL (แนะนำ Upstash) ไม่งั้น
#  rate limit/quota จะบังคับใช้แบบต่อ instance และ rate limiter จะ fail-closed
#  เมื่อ Redis ที่ตั้งไว้ล่ม
# ============================================================
REDIS_URL=

# ============================================================
#  SERVER (โหมด web service — key ผูกกับ account ผู้ใช้)
#  จำเป็นต้องตั้ง 2 ค่านี้เมื่อรัน `npm run server`
#  สร้างค่าแบบสุ่ม:  openssl rand -hex 32
# ============================================================
# ใช้เซ็น JWT (session token ของผู้ใช้) — token อายุ 7 วัน
JWT_SECRET=
# ใช้เข้ารหัส API key ของผู้ใช้ก่อนเก็บลง DB (AES-256-GCM + scrypt KDF)
COAGENTIX_MASTER_KEY=
# พอร์ตเซิร์ฟเวอร์ (ค่าเริ่มต้น 8787)
PORT=8787
# CORS: รายชื่อ origin ที่อนุญาต (คั่นด้วยจุลภาค)
# ตัวอย่าง: COAGENTIX_ALLOWED_ORIGINS=https://co-ai.vercel.app
COAGENTIX_ALLOWED_ORIGINS=
# Admin allowlist (คั่นด้วยจุลภาค) — username ที่เข้าถึง endpoint ระดับระบบได้:
#   backup / restore / disaster-recovery / failover / infra / platform analytics
# ถ้าไม่ตั้งค่า: ไม่มีใครเป็น admin และ endpoint เหล่านี้จะปฏิเสธทุกคน (secure by default)
# [DEPRECATED ตั้งแต่ Round 3] เดิมใช้ env นี้ให้สิทธิ์ admin ตาม username ซึ่งเสี่ยง
# privilege escalation. ตอนนี้ admin มาจาก DB (Supabase user_roles: OWNER/ADMIN/STAFF)
# ค่านี้ไม่ให้สิทธิ์ admin อีกต่อไป (ยังบล็อกการสมัครชื่อที่ตรงกันเพื่อกันความสับสน)
COAGENTIX_ADMIN_USERNAMES=
# break-glass: username ที่ได้สิทธิ์ admin ชั่วคราวเมื่อ DB role store เข้าถึงไม่ได้
# (ฉุกเฉินเท่านั้น — ทุกการใช้งานถูกบันทึก audit). ปกติเว้นว่าง
COAGENTIX_BREAKGLASS_ADMIN=

# ============================================================
#  PLAN ENFORCEMENT (Round 3 #6) — บังคับสิทธิ์ตาม subscription tier ฝั่ง server
#  ปิดโดยค่าเริ่มต้น (ยังไม่มีระบบเก็บเงิน). เปิด = '1' เพื่อบังคับ
#  tier มาจาก Supabase subscriptions (FREE/LITE/PRO/ADVANCED) เคารพ expires_at/revoked_at
# ============================================================
COAGENTIX_ENFORCE_PLANS=

# ============================================================
#  COST / TOKEN BUDGET (Round 1 #8) — เพดานต่อหนึ่งคำขอ
#  หยุดคำขอที่ใช้ทรัพยากรเกินกำหนดโดยอัตโนมัติ. ตั้ง 0 = ปิดเพดานนั้น
# ============================================================
# จำนวน token รวม (input+output) สูงสุดต่อ 1 orchestration (ค่าเริ่มต้น 2,000,000)
COAGENTIX_MAX_TOKENS=
# ค่าใช้จ่ายประมาณการสูงสุด (USD) ต่อ 1 orchestration (ค่าเริ่มต้น 2.0)
COAGENTIX_MAX_COST_USD=
# จำนวนการเรียก LLM สูงสุดต่อ 1 orchestration (ค่าเริ่มต้น 40)
COAGENTIX_MAX_LLM_CALLS=

# ============================================================
#  SANDBOX EXECUTION POLICY (Round 1 #5)
#  Node vm ไม่ได้แยก process จริง — ปิด fallback นี้ใน production
# ============================================================
# ปิดฟีเจอร์รันโค้ดทั้งหมด: SANDBOX_ENABLED=0
SANDBOX_ENABLED=
# บังคับใช้ Docker เท่านั้น (ถ้าไม่มี Docker จะปฏิเสธ) แม้อยู่นอก production
SANDBOX_REQUIRE_DOCKER=
# break-glass: อนุญาต Node vm แม้ใน production (ใช้เฉพาะเมื่อเชื่อถือ input เต็มที่)
SANDBOX_ALLOW_VM=
